TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLL_TIMEOUT_SECONDS=30
CODEX_BIN=codex
CODEX_PROVIDER=codex
CODEX_ADAPTER=auto
CODEX_WORKSPACE_ROOT=/absolute/path/to/workspaces
CODEX_PERMISSION_MODE=default
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro,gemini-3-flash-preview,gemini-3.1-pro-preview
BRIDGE_STATE_PATH=./data/bridge.db
BRIDGE_LANGUAGE=auto
BRIDGE_LOG_PATH=./data/logs/bridge.stdout.log
BRIDGE_LOG_LEVEL=info
BRIDGE_LOG_MAX_SIZE_MB=20
BRIDGE_LOG_MAX_BACKUPS=5
BRIDGE_PREVENT_SLEEP=true
